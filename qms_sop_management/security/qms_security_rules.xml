<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Multi-Company Rules for QMS Models -->
        <record id="rule_qms_sop_company" model="ir.rule">
            <field name="name">QMS SOP: Multi-Company Rule</field>
            <field name="model_id" ref="model_qms_sop"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
        </record>

