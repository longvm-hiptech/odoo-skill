<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Forms Action -->
    <record id="action_qms_sop_form" model="ir.actions.act_window">
        <field name="name">SOP Forms</field>
        <field name="res_model">qms.sop.form</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new SOP Form
            </p>
            <p>
                Track paper, electronic forms or appendices associated with standard operating procedures.
            </p>
        </field>
    </record>

    <!-- Forms List View -->
    <record id="view_qms_sop_form_list" model="ir.ui.view">
        <field name="name">qms.sop.form.list</field>
        <field name="model">qms.sop.form</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="sop_id"/>
                <field name="form_type"/>
                <field name="is_electronic" widget="boolean_toggle"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Forms Form View -->
    <record id="view_qms_sop_form_form" model="ir.ui.view">
        <field name="name">qms.sop.form.form</field>
        <field name="model">qms.sop.form</field>
        <field name="arch" type="xml">
            <form string="SOP Form">
                <sheet>
                    <div class="oe_title">
                        <h2>
                            <field name="code" readonly="1" invisible="not code"/>
                        </h2>
                        <h1>
                            <field name="name" placeholder="Form Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="SOP Association">
                            <field name="sop_id"/>
                            <field name="form_type"/>
                        </group>
                        <group string="Template &amp; Config">
                            <field name="is_electronic" readonly="1"/>
                            <field name="file_name" invisible="1"/>
                            <field name="file_binary" filename="file_name" widget="binary"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Forms Search View -->
    <record id="view_qms_sop_form_search" model="ir.ui.view">
        <field name="name">qms.sop.form.search</field>
        <field name="model">qms.sop.form</field>
        <field name="arch" type="xml">
            <search string="Search Forms">
                <field name="name"/>
                <field name="code"/>
                <field name="sop_id"/>
                <filter name="paper_forms" string="Paper Forms" domain="[('form_type', '=', 'S')]"/>
                <filter name="electronic_forms" string="Electronic Forms" domain="[('form_type', '=', 'E')]"/>
                <filter name="appendices" string="Appendices" domain="[('form_type', '=', 'A')]"/>
                <group>
                    <filter name="group_sop" string="SOP Document" context="{'group_by': 'sop_id'}"/>
                    <filter name="group_type" string="Form Type" context="{'group_by': 'form_type'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
