<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Spell Action -->
    <record id="action_qms_sop_spell" model="ir.actions.act_window">
        <field name="name">Spelling Corrections</field>
        <field name="res_model">qms.sop.spell</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Submit a Spelling Correction Request
            </p>
            <p>
                File quick typo/spelling corrections to active SOPs for QA approval.
            </p>
        </field>
    </record>

    <!-- Spell List View -->
    <record id="view_qms_sop_spell_list" model="ir.ui.view">
        <field name="name">qms.sop.spell.list</field>
        <field name="model">qms.sop.spell</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="sop_id"/>
                <field name="requester_id" widget="many2one_avatar_user"/>
                <field name="request_date"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-warning="state == 'submitted'" decoration-info="state == 'draft'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- Spell Form View -->
    <record id="view_qms_sop_spell_form" model="ir.ui.view">
        <field name="name">qms.sop.spell.form</field>
        <field name="model">qms.sop.spell</field>
        <field name="arch" type="xml">
            <form string="Spelling Correction Request">
                <header>
                    <button name="action_submit" string="Submit to QA" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-success" invisible="state != 'submitted'" groups="qms_sop_management.group_qms_qa"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'submitted'" groups="qms_sop_management.group_qms_qa"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group string="Basic Request Info">
                        <group>
                            <field name="sop_id" readonly="state != 'draft'"/>
                            <field name="requester_id" widget="many2one_avatar_user" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Correction Details">
                        <field name="correction_details" placeholder="Please specify: Page/Section/Line, Old text, and New text..." readonly="state != 'draft'"/>
                    </group>
                    <group string="QA Approval" invisible="state != 'approved'">
                        <field name="approver_id" widget="many2one_avatar_user"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Spell Search View -->
    <record id="view_qms_sop_spell_search" model="ir.ui.view">
        <field name="name">qms.sop.spell.search</field>
        <field name="model">qms.sop.spell</field>
        <field name="arch" type="xml">
            <search string="Search spelling requests">
                <field name="name"/>
                <field name="sop_id"/>
                <field name="requester_id"/>
                <filter name="my_requests" string="My Requests" domain="[('requester_id', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <group>
                    <filter name="group_sop" string="SOP" context="{'group_by': 'sop_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
