<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- SOP Window Action -->
    <record id="action_qms_sop" model="ir.actions.act_window">
        <field name="name">SOP Documents</field>
        <field name="res_model">qms.sop</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Standard Operating Procedure (SOP)
            </p>
            <p>
                Draft, review, approve, and track training for SOP documents in accordance with GMP.
            </p>
        </field>
    </record>

    <!-- SOP List View -->
    <record id="view_qms_sop_list" model="ir.ui.view">
        <field name="name">qms.sop.list</field>
        <field name="model">qms.sop</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'obsolete'" decoration-info="state in ('draft', 'review')" decoration-warning="state in ('approve', 'training')" decoration-success="state == 'effective'">
                <field name="code"/>
                <field name="name"/>
                <field name="building_code"/>
                <field name="dept_code"/>
                <field name="owner_id" widget="many2one_avatar_user"/>
                <field name="date_effective"/>
                <field name="date_review_deadline" widget="remaining_days"/>
                <field name="state" widget="badge" decoration-success="state == 'effective'" decoration-warning="state in ('approve', 'training')" decoration-info="state in ('draft', 'review')" decoration-muted="state == 'obsolete'"/>
            </list>
        </field>
    </record>

    <!-- SOP Form View -->
    <record id="view_qms_sop_form" model="ir.ui.view">
        <field name="name">qms.sop.form</field>
        <field name="model">qms.sop</field>
        <field name="arch" type="xml">
            <form string="SOP Document">
                <header>
                    <button name="action_submit_review" string="Submit for Review" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve (QA)" type="object" class="btn-success" invisible="state != 'review'" groups="qms_sop_management.group_qms_qa"/>
                    <button name="action_create_training_plan" string="Manage Training Plan" type="object" class="btn-primary" invisible="state not in ('approve', 'training')"/>
                    <button name="action_start_training" string="Start Training" type="object" class="btn-secondary" invisible="state != 'approve'" groups="qms_sop_management.group_qms_qa"/>
                    <button name="action_set_effective" string="Set Effective" type="object" class="btn-success" invisible="state != 'training'" groups="qms_sop_management.group_qms_qa"/>
                    <button name="action_create_new_edition" string="Create Revision" type="object" class="btn-warning" invisible="state != 'effective'"/>
                    <button name="action_renew_without_change" string="Renew Without Change" type="object" class="btn-secondary" invisible="state != 'effective'" groups="qms_sop_management.group_qms_qa"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state not in ('review', 'approve', 'training')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,approve,training,effective,obsolete"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Obsoleted" bg_color="bg-danger" invisible="state != 'obsolete'"/>
                    <widget name="web_ribbon" title="Effective" bg_color="bg-success" invisible="state != 'effective'"/>
                    <div class="oe_title">
                        <h2>
                            <field name="code" readonly="1" invisible="not code"/>
                        </h2>
                        <h1>
                            <field name="name" placeholder="SOP Title..." readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Categorization">
                            <field name="building_code" readonly="state != 'draft'"/>
                            <field name="dept_code" readonly="state != 'draft'"/>
                            <field name="change_control_id" readonly="state != 'draft'"/>
                            <field name="parent_sop_id"/>
                        </group>
                        <group string="Personnel">
                            <field name="owner_id" widget="many2one_avatar_user" readonly="state != 'draft'"/>
                            <field name="checker_ids" widget="many2many_tags" readonly="state != 'draft'"/>
                            <field name="approver_id" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Document &amp; Dates">
                        <group>
                            <field name="file_name" invisible="1"/>
                            <field name="file_binary" filename="file_name" widget="binary" readonly="state in ('effective', 'obsolete')"/>
                        </group>
                        <group>
                            <field name="date_approved"/>
                            <field name="date_effective"/>
                            <field name="date_review_deadline"/>
                            <field name="review_without_change_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Associated Forms" name="forms">
                            <field name="form_ids" readonly="state in ('effective', 'obsolete')">
                                <list editable="bottom">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="form_type"/>
                                    <field name="is_electronic" readonly="1"/>
                                    <field name="file_name" invisible="1"/>
                                    <field name="file_binary" filename="file_name" widget="binary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Associated Logbooks" name="logbooks">
                            <field name="logbook_ids" readonly="state in ('effective', 'obsolete')">
                                <list editable="bottom">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="page_count"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- SOP Search View -->
    <record id="view_qms_sop_search" model="ir.ui.view">
        <field name="name">qms.sop.search</field>
        <field name="model">qms.sop</field>
        <field name="arch" type="xml">
            <search string="Search SOPs">
                <field name="name"/>
                <field name="code"/>
                <field name="owner_id"/>
                <filter name="my_sops" string="My SOPs" domain="[('owner_id', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="review" string="Under Review" domain="[('state', '=', 'review')]"/>
                <filter name="training" string="Training Phase" domain="[('state', '=', 'training')]"/>
                <filter name="effective" string="Effective" domain="[('state', '=', 'effective')]"/>
                <filter name="obsolete" string="Obsoleted" domain="[('state', '=', 'obsolete')]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_building" string="Building" context="{'group_by': 'building_code'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'dept_code'}"/>
                    <filter name="group_owner" string="Owner" context="{'group_by': 'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
