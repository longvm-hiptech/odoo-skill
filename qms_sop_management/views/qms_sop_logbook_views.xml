<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Logbook Action -->
    <record id="action_qms_sop_logbook" model="ir.actions.act_window">
        <field name="name">Logbooks</field>
        <field name="res_model">qms.sop.logbook</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new Logbook
            </p>
            <p>
                Track paper logbooks with auto-numbered pages for records keeping under SOP requirements.
            </p>
        </field>
    </record>

    <!-- Logbook List View -->
    <record id="view_qms_sop_logbook_list" model="ir.ui.view">
        <field name="name">qms.sop.logbook.list</field>
        <field name="model">qms.sop.logbook</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-warning="state == 'closed'" decoration-danger="state == 'recalled'">
                <field name="code"/>
                <field name="name"/>
                <field name="sop_id"/>
                <field name="page_count"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'draft'" decoration-warning="state == 'closed'" decoration-danger="state == 'recalled'"/>
            </list>
        </field>
    </record>

    <!-- Logbook Form View -->
    <record id="view_qms_sop_logbook_form" model="ir.ui.view">
        <field name="name">qms.sop.logbook.form</field>
        <field name="model">qms.sop.logbook</field>
        <field name="arch" type="xml">
            <form string="Logbook">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close Logbook" type="object" class="btn-warning" invisible="state != 'active'"/>
                    <button name="action_recall" string="Recall Logbook" type="object" class="btn-danger" invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed,recalled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h2>
                            <field name="code" readonly="1" invisible="not code"/>
                        </h2>
                        <h1>
                            <field name="name" placeholder="Logbook Name..." readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group string="SOP Association">
                            <field name="sop_id" readonly="state != 'draft'"/>
                            <field name="page_count" readonly="state != 'draft'"/>
                        </group>
                        <group string="Configuration">
                            <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Logbook Search View -->
    <record id="view_qms_sop_logbook_search" model="ir.ui.view">
        <field name="name">qms.sop.logbook.search</field>
        <field name="model">qms.sop.logbook</field>
        <field name="arch" type="xml">
            <search string="Search Logbooks">
                <field name="name"/>
                <field name="code"/>
                <field name="sop_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="active" string="Active (In Use)" domain="[('state', '=', 'active')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <filter name="recalled" string="Recalled" domain="[('state', '=', 'recalled')]"/>
                <group>
                    <filter name="group_sop" string="SOP Document" context="{'group_by': 'sop_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
